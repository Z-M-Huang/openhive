# OpenHive Environment Variables
# Copy to .env and replace placeholder values before running.

# ── Required ──────────────────────────────────────────────────

# Root container toggle (set to "true" for the root container)
OPENHIVE_IS_ROOT=true

# AES-256-GCM master key for encrypting secrets (minimum 32 characters)
OPENHIVE_MASTER_KEY=replace-with-secure-random-key-minimum-32-chars

# Discord bot token (required if the discord channel is enabled)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# ── Optional overrides ───────────────────────────────────────

# Log level: trace | debug | info | warn | error | fatal
# OPENHIVE_LOG_LEVEL=info

# Path to the data directory (config files)
# OPENHIVE_DATA_DIR=data

# Path to the runtime directory (workspace, DB, archives)
# OPENHIVE_RUN_DIR=.run

# REST API listen address (host:port)
# OPENHIVE_SYSTEM_LISTEN_ADDRESS=127.0.0.1:8080
