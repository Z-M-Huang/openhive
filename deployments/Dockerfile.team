# OpenHive Team Container Base Image
# Node.js runtime for container orchestrator + Agent SDK instances
#
# Also serves as the base layer for the master image (Dockerfile).
# Any runtime dependency needed by both team and master containers
# should be added here — single source of truth.
#
# Runs as non-root user 'node' (UID 1000, from base image) — required
# because Claude Code refuses --dangerously-skip-permissions as root.

FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g bun@1.3.10

# Install Claude Code CLI as the non-root 'node' user (UID 1000).
USER node
RUN curl -fsSL https://claude.ai/install.sh | bash
ENV PATH="/home/node/.claude/bin:$PATH"

USER root
WORKDIR /app

# Copy compiled agent-runner (no source files — compiled-only policy).
COPY agent-runner/dist/ ./agent-runner/dist/
COPY agent-runner/package.json agent-runner/bun.lock ./agent-runner/

# Install production dependencies only.
RUN cd agent-runner && bun install --production --frozen-lockfile

# Ensure non-root user owns app and data directories.
RUN mkdir -p /app/data && chown -R node:node /app

USER node

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD node -e "process.exit(0)"

ENTRYPOINT ["node", "agent-runner/dist/index.js"]
