# OpenHive Provider Configuration
#
# Copy this file to providers.yaml and fill in your credentials:
#   cp data/providers.yaml.example data/providers.yaml
#
# This file contains sensitive credentials. providers.yaml is gitignored
# and should never be committed. Treat it like a .env file.
#
# Provider types:
#   oauth            - Claude Code OAuth subscription (sets CLAUDE_CODE_OAUTH_TOKEN)
#   anthropic_direct - Direct Anthropic API key (sets ANTHROPIC_API_KEY + ANTHROPIC_BASE_URL)
#
# Model tiers map skill-level names (haiku/sonnet/opus) to actual model identifiers.

providers:
  default:
    type: oauth
    oauth_token: ""
    models:
      haiku: haiku
      sonnet: sonnet
      opus: opus

  # Example: direct Anthropic API access
  # direct:
  #   type: anthropic_direct
  #   api_key: ""
  #   base_url: "https://api.anthropic.com"
  #   models:
  #     haiku: claude-3-haiku-20240307
  #     sonnet: claude-sonnet-4-20250514
  #     opus: claude-opus-4-20250514
