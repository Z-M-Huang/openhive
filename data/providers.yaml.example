# OpenHive Provider Configuration
#
# cp data/providers.yaml.example data/providers.yaml
#
# providers.yaml is gitignored — never commit it.

providers:
  # Option A: Claude Code OAuth (run "claude auth login", token is in ~/.claude/.credentials.json)
  default:
    type: oauth
    oauth_token: ""
    models:
      haiku: haiku
      sonnet: sonnet
      opus: opus

  # Option B: Direct Anthropic API key (https://console.anthropic.com/settings/keys)
  # direct:
  #   type: anthropic_direct
  #   api_key: ""                          # sk-ant-...
  #   base_url: "https://api.anthropic.com"
  #   models:
  #     haiku: claude-3-haiku-20240307
  #     sonnet: claude-sonnet-4-20250514
  #     opus: claude-opus-4-20250514
