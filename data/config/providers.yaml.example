# Provider profiles for OpenHive v3
# Copy to providers.yaml and fill in your API keys.

providers:
  - name: default-sonnet
    type: api
    api_url: https://api.anthropic.com
    api_key_ref: ANTHROPIC_API_KEY
    model: claude-sonnet-4-20250514

  - name: oauth-profile
    type: oauth
    oauth_token_env: OAUTH_TOKEN
