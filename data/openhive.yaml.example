# OpenHive Master Configuration
#
# cp data/openhive.yaml.example data/openhive.yaml
#
# openhive.yaml is gitignored — never commit it (contains channel tokens).

system:
  listen_address: "127.0.0.1:8080"
  data_dir: "data"
  workspace_root: "data/workspaces"
  log_level: "debug"
  log_archive:
    enabled: true
    max_entries: 100000
    keep_copies: 5
    archive_dir: "data/archives"

assistant:
  name: "OpenHive Assistant"
  aid: "aid-main-001"
  provider: "default"
  model_tier: "opus"
  max_turns: 50
  timeout_minutes: 10

channels:
  discord:
    enabled: false
    token: ""             # Bot token from https://discord.com/developers/applications
    channel_id: ""        # Right-click channel > Copy Channel ID
  whatsapp:
    enabled: false
    store_path: "data/whatsapp"  # Session persistence directory (QR auth on first run)
